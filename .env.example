# NeuralTradeMachine - copy this file to .env and fill in your values.
# Do not commit .env to version control.

# ---- API keys (required for full functionality) ----
# NewsAPI.org - https://newsapi.org/
NEWS_API_KEY=your_newsapi_key_here

# Google AI (Gemini) - https://ai.google.dev/
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Telegram bot (optional) - for alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ENABLED=false

# ---- NeuralTradeWeb (optional) ----
PORT=3000
BACKEND_URL=http://127.0.0.1:5001

# ---- NeuralTrade fusion / config (optional; defaults shown) ----
# STOCKS_LIST=TVSMOTOR.NS,TCS.NS,RELIANCE.NS
# CANDLE_TIMEFRAME_MINUTES=15
# FUSION_WEIGHT_TECHNICAL=0.35
# FUSION_WEIGHT_FUNDAMENTAL=0.35
# FUSION_WEIGHT_SENTIMENT=0.15
# FUSION_WEIGHT_RISK=0.15

# ---- Indicator module weights (optional) ----
# WEIGHT_RSI=10
# WEIGHT_STOCHRSI=7
# WEIGHT_MACD=15
# WEIGHT_MA_CROSSOVER=15
# WEIGHT_ADX=10
# WEIGHT_BOLLINGER=10
# WEIGHT_KELTNER=8
# WEIGHT_OBV=8
# WEIGHT_CCI=7
# WEIGHT_ROC=5

# ---- Trust module (optional) ----
# WEIGHT_EPS_GROWTH=15
# WEIGHT_REVENUE_GROWTH=15
# WEIGHT_ROE=12
# WEIGHT_DE_RATIO=12
# WEIGHT_PROFIT_MARGIN=10
# WEIGHT_FCF_TREND=12
# WEIGHT_CURRENT_RATIO=8
# WEIGHT_MARKETCAP_STABILITY=6
# WEIGHT_INSIDER_FLOW=10
# YEARS_TO_CHECK=3
# MIN_DATA_YEARS=1
